{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "idea-editor",
  "description": "Capability for the Idea Editor window",
  "windows": ["idea-editor"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:deny-clear",
    "store:deny-delete",
    "store:deny-entries",
    "store:deny-has",
    "store:deny-keys",
    "store:deny-length",
    "store:deny-reload",
    "store:deny-reset",
    "store:deny-values"
  ]
}
