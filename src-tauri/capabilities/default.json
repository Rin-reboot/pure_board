{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:default",
    "core:window:allow-set-always-on-top",
    "core:window:allow-close",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:deny-clear",
    "store:deny-delete",
    "store:deny-entries",
    "store:deny-has",
    "store:deny-keys",
    "store:deny-length",
    "store:deny-reload",
    "store:deny-reset",
    "store:deny-values"
  ]
}
